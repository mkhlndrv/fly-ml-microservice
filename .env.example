# Fly deploy settings. Copy to .env and fill in the app names your instructor
# assigned you (these are NOT secrets, but .env is gitignored anyway).
#
#   export $(grep -v '^#' .env | xargs)   # load into your shell before deploying

FLY_ORG=harbour-ml-solution-course
FLY_REGION=fra

# Instructor-assigned app names (example format):
#   <you>-harbour-compose  and  <you>-harbour-images
COMPOSE_APP=<your-compose-app>
IMAGES_APP=<your-images-app>
